# Django
DJANGO_SETTINGS_MODULE=liquidgo.settings.dev
DJANGO_SECRET_KEY=change-me-in-production-use-a-long-random-string
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Database
DATABASE_URL=postgres://liquidgo:liquidgo@localhost:5433/liquidgo

# Redis (Channels + Celery)
REDIS_URL=redis://localhost:6379/0

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# JWT
JWT_ACCESS_TTL_MINUTES=60
JWT_REFRESH_TTL_DAYS=14

# Cloudinary
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Mapbox (server-side, used for Directions API)
MAPBOX_SECRET_TOKEN=

# Paystack
PAYSTACK_SECRET_KEY=
PAYSTACK_PUBLIC_KEY=
PAYSTACK_WEBHOOK_SECRET=

# mNotify (SMS)
MNOTIFY_API_KEY=
MNOTIFY_SENDER_ID=Biniman

# Firebase Cloud Messaging
FCM_SERVER_KEY=

# Sentry
SENTRY_DSN=
